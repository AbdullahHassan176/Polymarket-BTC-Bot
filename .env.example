# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Your MetaMask private key (no 0x prefix).
# Export from: MetaMask -> Account Details -> Export Private Key
POLY_PRIVATE_KEY=your_private_key_here_without_0x_prefix

# Your Polygon wallet address (the 0x... address, not the private key).
POLY_WALLET_ADDRESS=0xYourWalletAddressHere

# Optional: for arbitrage checker (run_arbitrage_check --api). Claude API for fair-value analysis.
# ANTHROPIC_API_KEY=sk-ant-...
