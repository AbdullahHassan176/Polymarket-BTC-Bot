# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ===========================================================================
# POLYMARKET AUTHENTICATION (choose one mode)
# ===========================================================================

# ---------------------------------------------------------------------------
# MODE A: EOA (MetaMask - single wallet)
# ---------------------------------------------------------------------------
# One wallet: holds USDC + signs + pays gas.
# POLY_PRIVATE_KEY=your_private_key_without_0x_prefix
# POLY_WALLET_ADDRESS=0xYourWalletAddress

# ---------------------------------------------------------------------------
# MODE B: PROXY (Gnosis Safe)  <-- recommended for Polymarket
# ---------------------------------------------------------------------------
# Two addresses:
#   EOA (from PRIVATE_KEY): signs orders, signs Safe txs, pays gas (MATIC). Holds MATIC only.
#   Safe (from PROXY_WALLET): holds USDC + positions. CLOB funder.
#
# Find your Safe: https://safe-transaction-polygon.safe.global/api/v1/owners/{EOA_ADDRESS}/safes/
#
# PRIVATE_KEY=your_eoa_private_key_without_0x
# PROXY_WALLET=0xYourGnosisSafeAddress

# ---------------------------------------------------------------------------
# Optional: Polymarket API creds (from Polymarket Profile -> API Keys)
# ---------------------------------------------------------------------------
# If unset, derived from private key. Set explicitly for stability.
# POLYMARKET_API_KEY=
# POLYMARKET_API_SECRET=
# POLYMARKET_API_PASSPHRASE=

# ===========================================================================
# TRADING ASSET  (optional, for multi-asset 5-min testing)
# ===========================================================================
# Run one bot per asset. Each uses its own state file (state_ETH.json, etc.; BTC uses state.json).
# TRADING_ASSET=BTC
# TRADING_ASSET=ETH
# TRADING_ASSET=XRP
# TRADING_ASSET=SOL
# TRADING_ASSET=DOGE

# ===========================================================================
# REVERSAL ENTRY MODE  (optional)
# ===========================================================================
# single   = First tier wins, full stake at one price (default).
# pyramid  = Split stake across 20c, 15c, 10c as price hits each tier.
# REVERSAL_ENTRY_MODE=single
# REVERSAL_ENTRY_MODE=pyramid

# ===========================================================================
# OTHER
# ===========================================================================
# Optional: arbitrage checker (run_arbitrage_check --api)
# ANTHROPIC_API_KEY=sk-ant-...
